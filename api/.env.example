# ---- Backend MedLaudo-AI (VM com GPU) — exemplo de configuração ----

# Banco: cole a connection string do Neon (aceita o formato cru do Neon).
# Ex.: postgresql://usuario:senha@ep-xxxx.sa-east-1.aws.neon.tech/medlaudo?sslmode=require
DATABASE_URL=

# MedGemma em GPU (vLLM). Vazio => modo MOCK (sem leitura real da imagem).
MEDGEMMA_BASE_URL=http://localhost:8000/v1
MEDGEMMA_MODEL=google/medgemma-4b-it
HF_TOKEN=

# Autenticação JWT — gere um segredo forte (ex.: openssl rand -hex 32).
JWT_SECRET=
JWT_EXPIRA_HORAS=12

# CORS: domínio do frontend no Vercel.
CORS_ORIGINS=https://medlaudo.vercel.app

# Inferência assíncrona (fila + worker). "1" volta ao síncrono (testes).
INFERENCIA_SINCRONA=0

# Worklist automática do Orthanc.
ORTHANC_POLL=1
ORTHANC_URL=http://orthanc:8042
ORTHANC_POLL_INTERVALO=10

# Envio do laudo assinado de volta ao PACS.
PACS_ENVIO_AUTO=1
PACS_HOST=orthanc
PACS_PORT=4242
PACS_AE_TITLE=ORTHANC
PACS_CALLING_AE=MEDLAUDO

# Grounding (MedSigLIP) — opcional.
GROUNDING_ATIVO=0
# MEDSIGLIP_BASE_URL=http://medsiglip:8001
# INDICE_REFERENCIA=/dados/indice.json

# Onde as imagens de-identificadas são persistidas (disco da VM).
DADOS_DIR=/dados
